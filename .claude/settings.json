{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Read(**/node_modules/**)",
      "Read(**/.next/**)",
      "Read(**/.venv/**)",
      "Read(**/__pycache__/**)",
      "Read(**/.pytest_cache/**)",
