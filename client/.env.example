# Copy to .env.local for local development:
#   cp .env.example .env.local

# Browser-facing API URL (must match backend port / CORS_ORIGINS)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Engineering UI (context monitor, Sources on replies, memory inspector).
# Normal users see a plain chat only. Also: open app with ?debug=1
# NEXT_PUBLIC_DEV_TOOLS=1
