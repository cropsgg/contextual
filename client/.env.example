# Copy to .env.local for local development:
#   cp .env.example .env.local

# Local dev only: browser calls FastAPI directly (must match CORS_ORIGINS on the API).
NEXT_PUBLIC_API_URL=http://localhost:8000

# Production (Railway UI service, runtime — not NEXT_PUBLIC): backend origin for /api rewrites.
# BACKEND_URL=https://your-api.up.railway.app

# Engineering UI (context monitor, Sources on replies, memory inspector).
# Normal users see a plain chat only. Also: open app with ?debug=1
# NEXT_PUBLIC_DEV_TOOLS=1
