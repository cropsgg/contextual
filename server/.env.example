# Copy to .env and fill in secrets:
#   cp .env.example .env

# --- Database (docker compose postgres) ---
DATABASE_URL=postgresql+psycopg2://contextual_app:maestro_dev@127.0.0.1:5433/maestro
ADMIN_DATABASE_URL=postgresql+psycopg2://maestro:maestro_dev@127.0.0.1:5433/maestro
APP_DB_PASSWORD=maestro_dev

# --- Auth ---
JWT_SECRET=change-me-to-a-long-random-string
# Seeded admin (same login URL as users); expert preview enabled
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-admin-password
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# --- API / CORS ---
CORS_ORIGINS=http://localhost:3000
# Railway: set to the UI public URL (or use CORS_ORIGINS alone with the same value).
# FRONTEND_PUBLIC_URL=https://contextual-production-a977.up.railway.app
ENVIRONMENT=development

# --- Phase 4: limits & security ---
MESSAGE_MAX_LENGTH=8000
CHAT_RATE_LIMIT=30/minute
AUTH_RATE_LIMIT=10/minute

# --- DeepSeek (chat, summarization, rerank, fact extraction) ---
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
# Chat tier models (quota: 1M primary + 1M fallback per user per UTC day)
DEEPSEEK_MODEL_TIER_PRIMARY=deepseek-v4-flash
DEEPSEEK_MODEL_TIER_FALLBACK=deepseek-chat
DEFAULT_QUOTA_PRIMARY_DAILY=1000000
DEFAULT_QUOTA_FALLBACK_DAILY=1000000
DEEPSEEK_SUMMARIZE_MODEL=deepseek-chat
DEEPSEEK_RERANK_MODEL=deepseek-chat

# --- Context compression (Phase 2) ---
CONTEXT_THRESHOLD_TOKENS=4000
MIN_RECENT_MESSAGES_TO_KEEP=8

# --- Gemini embeddings (Phase 2 / 3) — required for memory retrieval ---
GEMINI_API_KEY=
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_EMBEDDING_DIMENSIONS=768

# --- Selective active-turn retrieval (Phase 5) ---
SELECTIVE_CONTEXT_ENABLED=true
PROMPT_TOKEN_BUDGET=8000
ACTIVE_RETRIEVAL_FLOOR_TURNS=6
ACTIVE_RETRIEVAL_TOP_K=8
ACTIVE_TURN_CHUNK_THRESHOLD_TOKENS=1000
ACTIVE_TURN_CHUNK_SIZE_TOKENS=500
ACTIVE_TURN_CHUNK_OVERLAP_TOKENS=50

# --- Adaptive retrieval & facts (Phase 3) ---
RETRIEVAL_TOP_K=5
RETRIEVAL_FINAL_K=2
RETRIEVAL_MIN_SCORE=0.35
FACT_EXTRACTION_EVERY_N_MESSAGES=4
FACT_EXTRACTION_LOOKBACK_MESSAGES=12

# Session extraction skips zero-signal batches when true (legacy conservative mode).
MEMORY_EXTRACTION_SKIP_IF_NO_SIGNALS=false
