# Copy to .env in the repo root for Docker Compose deployments:
#   cp .env.example .env
#
# Required before production:
#   JWT_SECRET          — long random string (never use the default)
#   CORS_ORIGINS        — browser origin(s) for the UI, comma-separated
#   NEXT_PUBLIC_API_URL — public API URL (baked into the frontend at BUILD time)
#   DEEPSEEK_API_KEY    — chat / summarization (required for chat to work)
#   GEMINI_API_KEY      — embeddings / memory retrieval (required for Phase 3)

# --- Public URLs (set to your cloud hostnames) ---
# Example: UI at https://app.example.com, API at https://api.example.com
NEXT_PUBLIC_API_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000

# --- Auth ---
JWT_SECRET=change-me-to-a-long-random-string

# --- Runtime ---
ENVIRONMENT=production

# --- LLM providers ---
DEEPSEEK_API_KEY=
GEMINI_API_KEY=

# --- Optional admin seed (first API startup) ---
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=change-me-admin-password
